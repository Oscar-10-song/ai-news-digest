{
  "buildCommand": "",
  "outputDirectory": ".",
  "installCommand": "npm install --production",
  "functions": {
    "api/webhook.ts": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/cron.ts": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 0 * * *"
    }
  ]
}
